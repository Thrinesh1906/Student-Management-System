{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 2,
    "restartPolicyType": "on-failure",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [
    "mongodb",
    "redis"
  ],
  "variables": {
    "MONGODB_URL": {
      "description": "MongoDB connection string",
      "value": "${{ plugin.mongodb.DATABASE_URL }}"
    },
    "REDIS_URL": {
      "description": "Redis connection string",
      "value": "${{ plugin.redis.REDIS_URL }}"
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "PORT": {
      "description": "Backend service port",
      "value": "5000"
    },
    "FRONTEND_URL": {
      "description": "Frontend application URL",
      "value": "https://${{ RAILWAY_PUBLIC_DOMAIN }}"
    },
    "JWT_SECRET": {
      "description": "JWT authentication secret",
      "value": ""
    },
    "JWT_REFRESH_SECRET": {
      "description": "JWT refresh token secret",
      "value": ""
    },
    "LOG_LEVEL": {
      "description": "Application logging level",
      "value": "info"
    }
  },
  "services": {
    "backend": {
      "builder": "nixpacks",
      "root": "backend",
      "startCommand": "npm run start",
      "buildCommand": "npm install && npm run build",
      "port": 5000,
      "domains": [
        "sms-backend"
      ],
      "healthChecks": {
        "httpPath": "/health",
        "interval": 30,
        "timeout": 5
      }
    },
    "frontend": {
      "builder": "nixpacks",
      "root": "frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run preview -- --host 0.0.0.0",
      "port": 5173,
      "domains": [
        "sms-frontend"
      ]
    },
    "mongodb": {
      "source": {
        "type": "image",
        "image": "mongo:7"
      },
      "port": 27017,
      "volumes": [
        {
          "name": "mongodb_data",
          "mountPath": "/data/db"
        }
      ]
    },
    "redis": {
      "source": {
        "type": "image",
        "image": "redis:7-alpine"
      },
      "port": 6379,
      "volumes": [
        {
          "name": "redis_data",
          "mountPath": "/data"
        }
      ]
    }
  }
}
