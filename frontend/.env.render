# Environment Variables for Render Frontend Deployment
# Update sms-backend with your actual Render backend domain
VITE_API_URL=https://sms-backend.onrender.com/api/v1
VITE_API_TIMEOUT=30000
VITE_APP_NAME=Student Management System
VITE_ENVIRONMENT=production
VITE_LOG_LEVEL=info
VITE_ENABLE_ANALYTICS=true
